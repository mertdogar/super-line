{
  "name": "@super-line/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "typedoc && node scripts/reference-index.mjs",
    "dev": "pnpm api && vitepress dev",
    "build": "pnpm api && vitepress build",
    "check-links": "linkinator .vitepress/dist --recurse --clean-urls --concurrency 1 --verbosity error --retry-errors --retry-errors-count 3 --skip '^https?://(?!localhost|127\\.0\\.0\\.1)'",
    "preview": "vitepress preview"
  },
  "dependencies": {
    "@super-line/client": "workspace:*",
    "@super-line/collections-memory": "workspace:*",
    "@super-line/core": "workspace:*",
    "@super-line/plugin-chat": "workspace:*",
    "@super-line/server": "workspace:*",
    "@super-line/transport-loopback": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "linkinator": "^7.6.1",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "vitepress": "^1.6.3",
    "vitepress-plugin-llms": "^1.13.2"
  }
}
