# Stage 1 — build the SPA from workspace source. vite resolves @super-line/* to src (see vite.config.ts),
# so the bundle is produced without publishing the packages.
FROM node:22-slim AS build
RUN corepack enable
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @super-line/example-ai-canvas-pglite build

# Stage 2 — Caddy serves the static bundle. No transport proxying: the browser dials a node's WebSocket
# port (8801 / 8802) directly. The Caddyfile is mounted at runtime (see docker-compose.yml).
FROM caddy:2
COPY --from=build /app/examples/ai-canvas-pglite/dist /srv
