# Stage 1 — build the SPA from workspace source. vite resolves @super-line/* to src (see
# vite.config.ts), so the bundle is produced without publishing the packages.
FROM node:22-slim AS build
RUN corepack enable
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @super-line/example-ai-canvas build

# Stage 2 — Caddy serves the static bundle. No transport proxying: the browser dials the node's
# WebSocket port (8796) directly. The Caddyfile is mounted at runtime (see docker-compose.yml).
FROM caddy:2
COPY --from=build /app/examples/ai-canvas/dist /srv
