# Stage 1 — build the SPA from workspace source. vite resolves @super-line/* to src (see
# vite.config.ts), so the bundle is produced without publishing the packages.
FROM node:22-slim AS build
RUN corepack enable
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @super-line/example-react-chat-transports build

# Stage 2 — Caddy serves the static bundle and reverse-proxies each transport to the node. The
# Caddyfile is mounted at runtime (see docker-compose.yml) so it stays editable without a rebuild.
FROM caddy:2
COPY --from=build /app/examples/react-chat-transports/dist /srv
