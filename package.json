{
  "name": "super-line",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Strictly-typed realtime data bus for TypeScript — requests, events, subscriptions & synced state from one contract.",
  "license": "MIT",
  "author": "Mert",
  "keywords": [
    "websocket",
    "typesafe",
    "realtime",
    "rooms",
    "pubsub",
    "rpc",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mertdogar/super-line.git"
  },
  "homepage": "https://github.com/mertdogar/super-line#readme",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:fast": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint packages examples",
    "changelog": "node scripts/changelog.mjs",
    "docs:packages": "pnpm --filter @super-line/core --filter @super-line/client --filter @super-line/server --filter @super-line/transport-loopback --filter @super-line/collections-memory --filter @super-line/plugin-auth --filter @super-line/plugin-chat build",
    "docs:dev": "pnpm --filter @super-line/docs dev",
    "docs:build": "pnpm docs:packages && pnpm --filter @super-line/docs build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "git-cliff": "2.13.1",
    "oxlint": "^0.15.0",
    "testcontainers": "^10.28.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
