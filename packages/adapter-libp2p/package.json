{
  "name": "@super-line/adapter-libp2p",
  "version": "0.6.2",
  "type": "module",
  "description": "libp2p (gossipsub) adapter for super-line — decentralized, broker-less multi-node fan-out + presence.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["websocket", "libp2p", "gossipsub", "p2p", "adapter", "scaling", "super-line"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/adapter-libp2p" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    }
  },
  "files": ["dist", "CHANGELOG.md"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
