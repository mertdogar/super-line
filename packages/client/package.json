{
  "name": "@super-line/client",
  "version": "0.1.0",
  "type": "module",
  "description": "Typesafe WebSocket client for super-line — typed calls, events, topics, auto-reconnect.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["websocket", "client", "typesafe", "realtime", "reconnect", "browser"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/client" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@super-line/core": "workspace:^"
  }
}
