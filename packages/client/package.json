{
  "name": "@super-line/client",
  "version": "0.13.0",
  "type": "module",
  "description": "Realtime data-bus client for super-line — typed calls, events, topics, collections, auto-reconnect over any transport.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["websocket", "client", "typesafe", "realtime", "reconnect", "browser"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/client" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "CHANGELOG.md"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup && node ../../scripts/check-changelog.mjs && node ../../scripts/check-manifest.mjs"
  },
  "dependencies": {
    "@logtape/logtape": "^2.2.4"
  },
  "peerDependencies": {
    "@super-line/core": ">=0.14.0 <1.0.0"
  },
  "devDependencies": {
    "@super-line/core": "workspace:^"
  }
}
