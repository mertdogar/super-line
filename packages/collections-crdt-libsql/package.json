{
  "name": "@super-line/collections-crdt-libsql",
  "version": "0.1.0",
  "type": "module",
  "description": "Durable CRDT (Yjs, via super-store) document collection backend for super-line — snapshot-per-doc to libsql/Turso.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["super-line", "collections", "crdt", "yjs", "libsql", "turso", "durable", "sync"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/collections-crdt-libsql" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@super-line/core": "workspace:^",
    "@super-line/collections-crdt-memory": "workspace:^",
    "@libsql/client": "^0.15.0"
  },
  "devDependencies": {
    "@super-store/store": "^0.3.0"
  }
}
