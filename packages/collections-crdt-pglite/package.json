{
  "name": "@super-line/collections-crdt-pglite",
  "version": "0.1.1",
  "type": "module",
  "description": "Self-clustering CRDT (Yjs, via super-store) document collection backend for super-line — an append-only op-log in central Postgres that ElectricSQL ships to a per-node PGlite replica; validate-before-commit at ingress; no adapter.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["super-line", "collections", "crdt", "yjs", "pglite", "postgres", "electric", "sync", "self", "collaboration"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/collections-crdt-pglite" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@super-line/core": "workspace:^",
    "@super-store/store": "^0.3.0",
    "@electric-sql/pglite": "^0.5.3",
    "@electric-sql/pglite-sync": "^0.6.3",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.2.6",
    "testcontainers": "^10.13.2"
  }
}
