{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "resolveJsonModule": true,
    "types": ["node", "vite/client"],
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@super-line/core": ["../core/src/index.ts"],
      "@super-line/server": ["../server/src/index.ts"],
      "@super-line/client": ["../client/src/index.ts"]
    }
  },
  "include": ["src", "test", "vite.config.ts"]
}
