{
  "name": "@super-line/plugin-chat",
  "version": "0.6.3",
  "type": "module",
  "description": "Chat backbone for super-line — channels, membership control, and messages backed by typed collections, with hookable server-authoritative requests. A paired plugin (contract · server). Requires @super-line/plugin-auth.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["super-line", "plugin", "chat", "channels", "messages", "membership"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/plugin-chat" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./server": {
      "import": { "types": "./dist/server.d.ts", "default": "./dist/server.js" },
      "require": { "types": "./dist/server.d.cts", "default": "./dist/server.cjs" }
    },
    "./client": {
      "import": { "types": "./dist/client.d.ts", "default": "./dist/client.js" },
      "require": { "types": "./dist/client.d.cts", "default": "./dist/client.cjs" }
    },
    "./react": {
      "import": { "types": "./dist/react.d.ts", "default": "./dist/react.js" },
      "require": { "types": "./dist/react.d.cts", "default": "./dist/react.cjs" }
    },
    "./ai-sdk": {
      "import": { "types": "./dist/ai.d.ts", "default": "./dist/ai.js" },
      "require": { "types": "./dist/ai.d.cts", "default": "./dist/ai.cjs" }
    },
    "./mastra": {
      "import": { "types": "./dist/mastra.d.ts", "default": "./dist/mastra.js" },
      "require": { "types": "./dist/mastra.d.cts", "default": "./dist/mastra.cjs" }
    }
  },
  "files": ["dist", "CHANGELOG.md"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup && node ../../scripts/check-changelog.mjs"
  },
  "dependencies": {
    "@super-line/core": "workspace:^",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@mastra/core": ">=1.50",
    "@super-line/client": "workspace:^",
    "@super-line/plugin-auth": "workspace:^",
    "@super-line/server": "workspace:^",
    "ai": ">=6",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@mastra/core": { "optional": true },
    "@super-line/client": { "optional": true },
    "@super-line/server": { "optional": true },
    "ai": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@mastra/core": "1.50.1",
    "@super-line/client": "workspace:^",
    "@super-line/collections-memory": "workspace:*",
    "@super-line/plugin-auth": "workspace:^",
    "@super-line/server": "workspace:^",
    "@super-line/transport-websocket": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.5",
    "ai": "^6.0.209",
    "jsdom": "^25.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.1"
  }
}
