{
  "name": "@super-line/react",
  "version": "0.8.0",
  "type": "module",
  "description": "React hooks for super-line — useRequest, useEvent, useSubscription.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["websocket", "react", "hooks", "typesafe", "realtime", "super-line"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/react" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@super-line/client": "workspace:^",
    "@super-line/core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@super-line/collections-memory": "workspace:*",
    "@super-line/server": "workspace:*",
    "@super-line/transport-websocket": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  }
}
