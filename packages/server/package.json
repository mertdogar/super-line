{
  "name": "@super-line/server",
  "version": "0.0.0",
  "type": "module",
  "description": "Typesafe WebSocket server for super-line — rooms, topics, middleware, pluggable adapters.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["websocket", "server", "typesafe", "realtime", "rooms", "pubsub", "ws"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/server" },
  "homepage": "https://github.com/mertdogar/super-line#readme",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
