{
  "name": "@super-line/server",
  "version": "0.2.0",
  "type": "module",
  "description": "Typesafe WebSocket server for super-line — rooms, topics, middleware, pluggable adapters.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["websocket", "server", "typesafe", "realtime", "rooms", "pubsub", "ws"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/server" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@super-line/core": "workspace:^",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@super-line/adapter-redis": "workspace:*",
    "@super-line/client": "workspace:*",
    "@types/ws": "^8.5.13",
    "ioredis": "^5.4.2",
    "testcontainers": "^10.13.2",
    "zod": "^3.24.1"
  }
}
