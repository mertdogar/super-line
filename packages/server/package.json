  "files": ["dist"],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@super-line/core": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@super-line/adapter-redis": "workspace:*",
    "@super-line/client": "workspace:*",
    "@types/ws": "^8.5.13",
    "testcontainers": "^10.13.2",
    "zod": "^3.24.1"
  }
