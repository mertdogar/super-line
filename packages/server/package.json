{
  "name": "@super-line/server",
  "version": "0.2.0",
  "type": "module",
  "description": "Typesafe WebSocket server for super-line — rooms, topics, middleware, pluggable adapters.",
  "license": "MIT",
  "author": "Mert",
  "keywords": [
    "websocket",
    "server",
    "typesafe",
    "realtime",
    "rooms",
    "pubsub",
    "ws"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mertdogar/super-line.git",
    "directory": "packages/server"
  },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@super-line/core": "workspace:^",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/crypto": "^5.1.20",
    "@libp2p/gossipsub": "^16.0.3",
    "@libp2p/identify": "^4.1.8",
    "@libp2p/interface": "^3.2.4",
    "@libp2p/memory": "^2.0.22",
    "@libp2p/tcp": "^11.0.22",
    "@super-line/adapter-libp2p": "workspace:*",
    "@super-line/adapter-redis": "workspace:*",
    "@super-line/adapter-zeromq": "workspace:*",
    "@super-line/client": "workspace:*",
    "@types/ws": "^8.5.13",
    "ioredis": "^5.4.2",
    "libp2p": "^3.3.4",
    "testcontainers": "^10.13.2",
    "zeromq": "^6.0.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "optionalDependencies": {
    "@standard-community/standard-json": "^0.3.5"
  }
}
