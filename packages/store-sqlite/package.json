{
  "name": "@super-line/store-sqlite",
  "version": "0.2.0",
  "type": "module",
  "description": "Durable last-writer-wins Store for super-line — SQLite-backed server persistence (better-sqlite3).",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["super-line", "store", "sqlite", "persistence", "durable", "lww"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/store-sqlite" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@super-line/core": "workspace:^",
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12"
  }
}
