{
  "name": "@super-line/tanstack-db",
  "version": "0.1.2",
  "type": "module",
  "description": "TanStack DB collection adapter for super-line — use super-line collections as a TanStack DB sync source with client-side live queries and joins.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["super-line", "tanstack", "tanstack-db", "collections", "sync", "live-query"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/tanstack-db" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@super-line/core": "workspace:^",
    "@super-line/client": "workspace:^"
  },
  "peerDependencies": {
    "@tanstack/db": ">=0.1"
  },
  "devDependencies": {
    "@super-line/collections-memory": "workspace:*",
    "@super-line/server": "workspace:*",
    "@super-line/transport-websocket": "workspace:*",
    "@tanstack/db": "^0.5.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  }
}
