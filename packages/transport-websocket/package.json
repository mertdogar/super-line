{
  "name": "@super-line/transport-websocket",
  "version": "0.7.0",
  "type": "module",
  "description": "WebSocket client↔server transport for super-line (Node `ws` server + browser/Node client).",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["super-line", "transport", "websocket", "ws", "realtime"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-line.git", "directory": "packages/transport-websocket" },
  "homepage": "https://mertdogar.github.io/super-line/",
  "bugs": "https://github.com/mertdogar/super-line/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "CHANGELOG.md"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup && node ../../scripts/check-changelog.mjs && node ../../scripts/check-manifest.mjs"
  },
  "dependencies": {
    "@logtape/logtape": "^2.2.4",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@super-line/core": ">=0.14.0 <1.0.0"
  },
  "devDependencies": {
    "@super-line/core": "workspace:^",
    "@types/ws": "^8.5.13"
  }
}
