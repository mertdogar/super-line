{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@super-line/core": ["./packages/core/src/index.ts"],
      "@super-line/server": ["./packages/server/src/index.ts"],
      "@super-line/client": ["./packages/client/src/index.ts"],
      "@super-line/adapter-redis": ["./packages/adapter-redis/src/index.ts"],
      "@super-line/adapter-libp2p": ["./packages/adapter-libp2p/src/index.ts"],
      "@super-line/adapter-zeromq": ["./packages/adapter-zeromq/src/index.ts"],
      "@super-line/adapter-rabbitmq": ["./packages/adapter-rabbitmq/src/index.ts"],
      "@super-line/react": ["./packages/react/src/index.ts"],
      "@super-line/plugin-inspector": ["./packages/plugin-inspector/src/index.ts"],
      "@super-line/plugin-auth": ["./packages/plugin-auth/src/index.ts"],
      "@super-line/plugin-auth/server": ["./packages/plugin-auth/src/server.ts"],
      "@super-line/plugin-auth/client": ["./packages/plugin-auth/src/client.ts"],
      "@super-line/plugin-auth/react": ["./packages/plugin-auth/src/react.tsx"],
      "@super-line/plugin-chat": ["./packages/plugin-chat/src/index.ts"],
      "@super-line/plugin-chat/server": ["./packages/plugin-chat/src/server.ts"],
      "@super-line/plugin-chat/client": ["./packages/plugin-chat/src/client.ts"],
      "@super-line/plugin-chat/react": ["./packages/plugin-chat/src/react.tsx"],
      "@super-line/plugin-chat/ai": ["./packages/plugin-chat/src/ai.ts"],
      "@super-line/collections-memory": ["./packages/collections-memory/src/index.ts"],
      "@super-line/collections-crdt-memory": ["./packages/collections-crdt-memory/src/index.ts"],
      "@super-line/collections-crdt-libsql": ["./packages/collections-crdt-libsql/src/index.ts"],
      "@super-line/collections-crdt-pglite": ["./packages/collections-crdt-pglite/src/index.ts"],
      "@super-line/collections-sqlite": ["./packages/collections-sqlite/src/index.ts"],
      "@super-line/collections-pglite": ["./packages/collections-pglite/src/index.ts"],
      "@super-line/tanstack-db": ["./packages/tanstack-db/src/index.ts"],
      "@super-line/transport-websocket": ["./packages/transport-websocket/src/index.ts"],
      "@super-line/transport-loopback": ["./packages/transport-loopback/src/index.ts"],
      "@super-line/transport-http": ["./packages/transport-http/src/index.ts"],
      "@super-line/transport-libp2p": ["./packages/transport-libp2p/src/index.ts"]
    }
  }
}
